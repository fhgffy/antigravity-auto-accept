{
  "name": "antigravity-auto-accept",
  "displayName": "Antigravity Auto Accept",
  "description": "Auto-accept Antigravity IDE permission prompts via UIAutomation. Zero manual clicks, no CDP port needed.",
  "version": "5.1.0",
  "license": "MIT",
  "icon": "icon.png",
  "publisher": "fhgffy",
  "repository": {
    "type": "git",
    "url": "https://github.com/fhgffy/antigravity-auto-accept.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "antigravity",
    "auto-accept",
    "automation",
    "agent",
    "cdp"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionKind": ["ui"],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "antigravity-auto-accept.start",
        "title": "Start Antigravity Auto Accept"
      },
      {
        "command": "antigravity-auto-accept.stop",
        "title": "Stop Antigravity Auto Accept"
      },
      {
        "command": "antigravity-auto-accept.toggle",
        "title": "Toggle Antigravity Auto Accept ON/OFF"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src --ext ts"
  },
  "dependencies": {
    "ws": "^8.16.0"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "@types/ws": "^8.5.10",
    "typescript": "^5.1.0"
  }
}